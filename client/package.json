{
  "name": "electron",
  "version": "2.0.32",
  "description": "Corporate Chat Client",
  "author": "bolgov@me.com",
  "homepage": "https://github.com/bolgov0zero/corp-chat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux --x64",
    "build:linux-arm": "electron-builder --linux --arm64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.corpchat.client",
    "productName": "Electron",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "../icons/app/icon-1024.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "../icons/app/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "../icons/app",
      "category": "Network",
      "maintainer": "bolgov@me.com"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "include": "build/installer.nsh"
    }
  }
}
