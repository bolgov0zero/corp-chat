#!/bin/bash

SERVICE="electron"
APP_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
DB_PATH="${DB_PATH:-$APP_DIR/../chat_db/chat.db}"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
NC=$'\033[0m'

SPIN_PID=""

trap 'kill "$SPIN_PID" 2>/dev/null; clear; exit 0' INT TERM

# ── Статус службы ──
get_status() {
  systemctl is-active "$SERVICE" 2>/dev/null
}

# ── Спиннер ──
start_spin() {
  local msg="$1"
  (
    local frames=('⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏')
    local i=0
    trap '' INT TERM
    while true; do
      printf "\r  ${CYAN}${frames[$i]}${NC}  $msg   "
      i=$(( (i+1) % 10 ))
      sleep 0.08
    done
  ) &
  SPIN_PID=$!
}

stop_spin() {
  local code=$1
  local msg="$2"
  { kill "$SPIN_PID" 2>/dev/null; wait "$SPIN_PID" 2>/dev/null; } 2>/dev/null
  SPIN_PID=""
  if [ "$code" = "0" ]; then
    printf "\r  ${GREEN}✓${NC}  %-42s\n" "$msg"
  else
    printf "\r  ${RED}✗${NC}  %-42s\n" "$msg"
  fi
}

# ── Информационная панель ──
show_panel() {
  clear
  local status
  status=$(get_status)

  if [ "$status" = "active" ]; then
    STATUS_COLOR=$GREEN
    STATUS_ICON="●"
    STATUS_TEXT="Работает"
  else
    STATUS_COLOR=$RED
    STATUS_ICON="○"
    STATUS_TEXT="Остановлен"
  fi

  [ -f "$DB_PATH" ] && DB_SIZE=$(du -sh "$DB_PATH" 2>/dev/null | cut -f1) || DB_SIZE="—"

  if command -v sqlite3 &>/dev/null && [ -f "$DB_PATH" ]; then
    USER_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM users;" 2>/dev/null || echo "—")
    MSG_COUNT=$(sqlite3  "$DB_PATH" "SELECT COUNT(*) FROM messages;" 2>/dev/null || echo "—")
    CHAT_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM chats;" 2>/dev/null || echo "—")
  else
    USER_COUNT="—"; MSG_COUNT="—"; CHAT_COUNT="—"
  fi

  PORT=$(systemctl show "$SERVICE" --property=Environment --value 2>/dev/null | grep -o 'PORT=[0-9]*' | cut -d= -f2)
  PORT="${PORT:-3000}"

  VERSION_FILE="$APP_DIR/version.json"
  if command -v node &>/dev/null && [ -f "$VERSION_FILE" ]; then
    SERVER_VERSION=$(node -e "try{process.stdout.write(require('$VERSION_FILE').version)}catch{process.stdout.write('—')}" 2>/dev/null)
  else
    SERVER_VERSION="—"
  fi

  UPTIME_STR="—"
  if [ "$status" = "active" ]; then
    START_TS=$(systemctl show "$SERVICE" --property=ActiveEnterTimestampMonotonic --value 2>/dev/null)
    if [ -n "$START_TS" ] && [ "$START_TS" != "0" ]; then
      NOW_MONO=$(awk '{printf "%.0f", $1 * 1000000}' /proc/uptime)
      ELAPSED_SEC=$(( (NOW_MONO - START_TS) / 1000000 ))
      DAYS=$(( ELAPSED_SEC / 86400 ))
      HOURS=$(( (ELAPSED_SEC % 86400) / 3600 ))
      MINS=$(( (ELAPSED_SEC % 3600) / 60 ))
      if   [ $DAYS  -gt 0 ]; then UPTIME_STR="${DAYS}д ${HOURS}ч ${MINS}м"
      elif [ $HOURS -gt 0 ]; then UPTIME_STR="${HOURS}ч ${MINS}м"
      else                        UPTIME_STR="${MINS}м"; fi
    fi
  fi

  NOW=$(date "+%H:%M:%S")

  printf "\n"
  printf "  ${BOLD}╔══════════════════════════════════════════════╗${NC}\n"
  printf "  ${BOLD}║         ⚡  Electron  Server                 ║${NC}\n"
  printf "  ${BOLD}╚══════════════════════════════════════════════╝${NC}\n"
  printf "\n"
  printf "  ${STATUS_COLOR}${BOLD}%s${NC}  ${BOLD}%-10s${NC}${STATUS_COLOR}%s${NC}   ${DIM}%s${NC}\n" \
    "$STATUS_ICON" "Статус:" "$STATUS_TEXT" "$NOW"

  if [ "$status" = "active" ]; then
    printf "     ${BOLD}%-10s${NC}${DIM}%s${NC}\n" "Версия:"  "$SERVER_VERSION"
    printf "     ${BOLD}%-10s${NC}${DIM}%s${NC}\n" "Аптайм:"  "$UPTIME_STR"
    printf "     ${BOLD}%-10s${NC}${DIM}%s${NC}\n" "Порт:"    "$PORT"
  fi

  printf "\n"
  printf "  ${DIM}────────────────────────────────────────────${NC}\n"
  printf "  ${CYAN}  ${BOLD}%-16s${NC}${CYAN}%s${NC}\n"       "Пользователи"  "$USER_COUNT"
  printf "  ${CYAN}  ${BOLD}%-16s${NC}${CYAN}%s${NC}\n"       "Сообщений"     "$MSG_COUNT"
  printf "  ${CYAN}  ${BOLD}%-16s${NC}${CYAN}%s${NC}  ${DIM}(%s)${NC}\n" "Чатов" "$CHAT_COUNT" "$DB_SIZE"
  printf "  ${DIM}────────────────────────────────────────────${NC}\n"
  printf "\n"

  if [ "$status" = "active" ]; then
    printf "  ${DIM}[1]${NC} Остановить    ${DIM}[2]${NC} Перезапустить\n"
  else
    printf "  ${DIM}[1]${NC} Запустить     ${DIM}[2]${NC} Перезапустить\n"
  fi
  printf "  ${DIM}[3]${NC} Обновить      ${DIM}[4]${NC} Логи\n"
  printf "  ${DIM}[0]${NC} Выйти\n"
  printf "\n"
  printf "  → "
}

# ── Обновление с GitHub ──
do_update() {
  clear
  printf "\n"
  printf "  ${BOLD}╔══════════════════════════════════════════════╗${NC}\n"
  printf "  ${BOLD}║           Обновление сервера                 ║${NC}\n"
  printf "  ${BOLD}╚══════════════════════════════════════════════╝${NC}\n"
  printf "\n"

  cd "$APP_DIR"

  # Шаг 1: git
  start_spin "Проверка репозитория"
  if ! command -v git &>/dev/null || ! git rev-parse --git-dir &>/dev/null; then
    stop_spin 1 "git недоступен"
    printf "\n  Нажми Enter..."; read -r
    return 1
  fi
  stop_spin 0 "Репозиторий найден"

  # Шаг 2: fetch
  start_spin "Загрузка обновлений"
  if ! git fetch origin main >/tmp/electron-update.log 2>&1; then
    stop_spin 1 "Нет доступа к GitHub"
    printf "\n  Нажми Enter..."; read -r
    return 1
  fi

  LOCAL=$(git rev-parse HEAD)
  REMOTE=$(git rev-parse origin/main)

  if [ "$LOCAL" = "$REMOTE" ]; then
    stop_spin 0 "Уже последняя версия"
    printf "\n"
    sleep 2
    return 0
  fi

  SHORT_FROM=$(git rev-parse --short HEAD)
  SHORT_TO=$(git rev-parse --short origin/main)
  stop_spin 0 "Загружено ($SHORT_FROM → $SHORT_TO)"

  # Шаг 3: apply
  start_spin "Применение изменений"
  if ! git reset --hard origin/main >>/tmp/electron-update.log 2>&1; then
    stop_spin 1 "Не удалось применить изменения"
    printf "\n  Нажми Enter..."; read -r
    return 1
  fi
  stop_spin 0 "Изменения применены"

  # Шаг 4: npm install
  start_spin "Установка зависимостей"
  if ! npm install --omit=dev >>/tmp/electron-update.log 2>&1; then
    stop_spin 1 "npm install завершился с ошибкой"
    printf "\n  ${DIM}Лог: /tmp/electron-update.log${NC}\n"
    printf "\n  Нажми Enter..."; read -r
    return 1
  fi
  stop_spin 0 "Зависимости установлены"

  # Шаг 5: rebuild
  start_spin "Пересборка модулей"
  npm rebuild better-sqlite3 >>/tmp/electron-update.log 2>&1
  stop_spin 0 "Модули пересобраны"

  # Шаг 6: restart
  start_spin "Перезапуск службы"
  systemctl restart "$SERVICE" >>/tmp/electron-update.log 2>&1
  sleep 2

  if systemctl is-active --quiet "$SERVICE"; then
    stop_spin 0 "Служба запущена"
  else
    stop_spin 1 "Служба не стартовала"
    printf "\n  ${DIM}Лог: /tmp/electron-update.log${NC}\n"
    printf "\n  Нажми Enter..."; read -r
    return 1
  fi

  NEW_VER=$(node -e "process.stdout.write(require('$APP_DIR/version.json').version)" 2>/dev/null)
  printf "\n  ${GREEN}${BOLD}✓ Обновление завершено — %s${NC}\n\n" "$NEW_VER"
  printf "  Нажми Enter для возврата..."
  read -r
}

# ── Главный цикл ──
while true; do
  show_panel
  read -t 5 -r choice
  RC=$?

  [ $RC -gt 128 ] && continue  # таймаут — обновить панель (живой аптайм/время)

  local_status=$(get_status)
  case "$choice" in
    1)
      if [ "$local_status" = "active" ]; then
        systemctl stop "$SERVICE" 2>/dev/null
      else
        systemctl start "$SERVICE" 2>/dev/null
      fi
      sleep 1
      ;;
    2)
      systemctl restart "$SERVICE" 2>/dev/null
      sleep 1
      ;;
    3) do_update ;;
    4)
      clear
      printf "\n"
      journalctl -u "$SERVICE" -n 40 --no-pager
      printf "\n  Нажми Enter для возврата..."
      read -r
      ;;
    0|q|Q)
      clear
      exit 0
      ;;
  esac
done
