#!/bin/bash

SERVICE="electron"
APP_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
GITHUB_REPO="bolgov0zero/corp-chat"
DB_PATH="${DB_PATH:-$APP_DIR/../chat_db/chat.db}"

# ── Цвета ──
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Статус службы ──
get_status() {
  systemctl is-active "$SERVICE" 2>/dev/null
}

# ── Информационная панель ──
show_panel() {
  clear
  local status=$(get_status)
  local uptime_str=""
  local pid_str=""

  if [ "$status" = "active" ]; then
    STATUS_COLOR=$GREEN
    STATUS_ICON="●"
    STATUS_TEXT="Работает"
    uptime_str=$(systemctl show "$SERVICE" --property=ActiveEnterTimestamp --value 2>/dev/null | xargs -I{} date -d "{}" "+%d.%m.%Y %H:%M" 2>/dev/null || echo "—")
    pid_str=$(systemctl show "$SERVICE" --property=MainPID --value 2>/dev/null || echo "—")
  else
    STATUS_COLOR=$RED
    STATUS_ICON="○"
    STATUS_TEXT="Остановлен"
  fi

  # Размер БД
  if [ -f "$DB_PATH" ]; then
    DB_SIZE=$(du -sh "$DB_PATH" 2>/dev/null | cut -f1)
  else
    DB_SIZE="—"
  fi

  # Кол-во пользователей
  if command -v sqlite3 &>/dev/null && [ -f "$DB_PATH" ]; then
    USER_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM users;" 2>/dev/null || echo "—")
    MSG_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM messages;" 2>/dev/null || echo "—")
    CHAT_COUNT=$(sqlite3 "$DB_PATH" "SELECT COUNT(*) FROM chats;" 2>/dev/null || echo "—")
  else
    USER_COUNT="—"
    MSG_COUNT="—"
    CHAT_COUNT="—"
  fi

  # Порт
  PORT=$(systemctl show "$SERVICE" --property=Environment --value 2>/dev/null | grep -o 'PORT=[0-9]*' | cut -d= -f2)
  PORT="${PORT:-3000}"

  # Версия сервера
  VERSION_FILE="$APP_DIR/version.json"
  if command -v node &>/dev/null && [ -f "$VERSION_FILE" ]; then
    SERVER_VERSION=$(node -e "try{process.stdout.write(require('$VERSION_FILE').version)}catch{process.stdout.write('—')}" 2>/dev/null)
  else
    SERVER_VERSION="—"
  fi

  # Аптайм
  UPTIME_STR="—"
  if [ "$status" = "active" ]; then
    START_TS=$(systemctl show "$SERVICE" --property=ActiveEnterTimestampMonotonic --value 2>/dev/null)
    if [ -n "$START_TS" ] && [ "$START_TS" != "0" ]; then
      NOW_MONO=$(cat /proc/uptime | awk '{print int($1 * 1000000)}')
      ELAPSED_US=$(( NOW_MONO - START_TS ))
      ELAPSED_SEC=$(( ELAPSED_US / 1000000 ))
      DAYS=$(( ELAPSED_SEC / 86400 ))
      HOURS=$(( (ELAPSED_SEC % 86400) / 3600 ))
      MINS=$(( (ELAPSED_SEC % 3600) / 60 ))
      if [ $DAYS -gt 0 ]; then
        UPTIME_STR="${DAYS}д ${HOURS}ч ${MINS}м"
      elif [ $HOURS -gt 0 ]; then
        UPTIME_STR="${HOURS}ч ${MINS}м"
      else
        UPTIME_STR="${MINS}м"
      fi
    fi
  fi

  echo ""
  echo -e "  ${BOLD}╔══════════════════════════════════════════════╗${NC}"
  echo -e "  ${BOLD}║           Electron — Управление              ║${NC}"
  echo -e "  ${BOLD}╚══════════════════════════════════════════════╝${NC}"
  echo ""
  echo -e "  ${BOLD}Статус:${NC}      ${STATUS_COLOR}${STATUS_ICON} ${STATUS_TEXT}${NC}"
  if [ "$status" = "active" ]; then
    echo -e "  ${BOLD}Версия:${NC}      ${DIM}${SERVER_VERSION}${NC}"
    echo -e "  ${BOLD}Аптайм:${NC}      ${DIM}${UPTIME_STR}${NC}"
    echo -e "  ${BOLD}Запущен:${NC}     ${DIM}${uptime_str}${NC}"
    echo -e "  ${BOLD}Порт:${NC}        ${DIM}${PORT}${NC}"
  fi
  echo ""
  echo -e "  ${BOLD}── База данных ─────────────────────────────${NC}"
  echo -e "  ${BOLD}Размер БД:${NC}   ${CYAN}${DB_SIZE}${NC}"
  echo -e "  ${BOLD}Пользователи:${NC}${CYAN}${USER_COUNT}${NC}"
  echo -e "  ${BOLD}Сообщений:${NC}   ${CYAN}${MSG_COUNT}${NC}"
  echo -e "  ${BOLD}Чатов:${NC}       ${CYAN}${CHAT_COUNT}${NC}"
  echo ""
  echo -e "  ${BOLD}── Действия ────────────────────────────────${NC}"

  if [ "$status" = "active" ]; then
    echo -e "  ${BOLD}1.${NC} Остановить"
  else
    echo -e "  ${BOLD}1.${NC} Запустить"
  fi
  echo -e "  ${BOLD}2.${NC} Перезапустить"
  echo -e "  ${BOLD}3.${NC} Обновить сервер с GitHub"
  echo -e "  ${BOLD}4.${NC} Показать логи"
  echo -e "  ${BOLD}0.${NC} Выйти"
  echo ""
  echo -ne "  Выбери действие: "
}

# ── Обновление с GitHub ──
do_update() {
  echo ""
  echo -e "  ${YELLOW}→ Получение обновлений с GitHub...${NC}"

  cd "$APP_DIR"

  # Проверяем git
  if ! command -v git &>/dev/null; then
    echo -e "  ${RED}✗ git не установлен${NC}"
    return 1
  fi

  if ! git rev-parse --git-dir &>/dev/null; then
    echo -e "  ${RED}✗ Папка не является git-репозиторием${NC}"
    return 1
  fi

  LOCAL=$(git rev-parse HEAD)
  git fetch origin main -q
  REMOTE=$(git rev-parse origin/main)

  if [ "$LOCAL" = "$REMOTE" ]; then
    echo -e "  ${GREEN}✓ Уже установлена последняя версия${NC}"
    sleep 2
    return 0
  fi

  echo -e "  ${YELLOW}→ Применение изменений...${NC}"
  git pull origin main -q

  echo -e "  ${YELLOW}→ Установка зависимостей...${NC}"
  npm install --omit=dev -q

  echo -e "  ${YELLOW}→ Пересборка нативных модулей...${NC}"
  npm rebuild better-sqlite3 -q

  echo -e "  ${YELLOW}→ Перезапуск службы...${NC}"
  systemctl restart "$SERVICE"
  sleep 2

  if systemctl is-active --quiet "$SERVICE"; then
    echo -e "  ${GREEN}✓ Обновление успешно применено${NC}"
  else
    echo -e "  ${RED}✗ Служба не запустилась после обновления${NC}"
    echo -e "  ${DIM}journalctl -u $SERVICE -n 20 --no-pager${NC}"
  fi
  sleep 3
}

# ── Главный цикл ──
while true; do
  show_panel
  read -r choice

  case "$choice" in
    1)
      status=$(get_status)
      if [ "$status" = "active" ]; then
        echo -e "\n  ${YELLOW}→ Остановка...${NC}"
        systemctl stop "$SERVICE"
      else
        echo -e "\n  ${YELLOW}→ Запуск...${NC}"
        systemctl start "$SERVICE"
      fi
      sleep 2
      ;;
    2)
      echo -e "\n  ${YELLOW}→ Перезапуск...${NC}"
      systemctl restart "$SERVICE"
      sleep 2
      ;;
    3)
      do_update
      ;;
    4)
      echo ""
      journalctl -u "$SERVICE" -n 40 --no-pager
      echo ""
      echo -ne "  Нажми Enter для возврата..."
      read -r
      ;;
    0|q|Q)
      echo ""
      exit 0
      ;;
    *)
      ;;
  esac
done
